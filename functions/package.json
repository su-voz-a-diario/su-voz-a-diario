{
  "name": "su-voz-functions",
  "description": "Cloud Functions for Su Voz a Diario",
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "check": "node --check index.js",
    "migrate:community:last-activity": "node migrateCommunityLastActivity.js",
    "test:bible-proxy": "node bibleProxy.test.js",
    "serve": "firebase emulators:start --only functions,firestore",
    "shell": "firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5"
  },
  "private": true
}
